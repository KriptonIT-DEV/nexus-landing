---
import Main from "@/layouts/Main.astro"
import Container from "@/components/layout/Container.astro"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import { ArrowRight } from "lucide-react"

interface Props {
  title: string
  description: string
  updatedAt: string
  sections: { id: string; label: string }[]
  cta: {
    title: string
    description: string
  }
}

const { title, description, updatedAt, sections, cta } = Astro.props
---

<Main title={`${title} | Konnect 360`}>
  {/* Hero */}
  <section class="border-b border-border bg-secondary/30">
    <Container size="default" class="py-12 md:py-16">
      <div class="flex flex-col gap-3">
        <Badge variant="outline" className="w-fit font-mono text-xs uppercase tracking-[0.2em]">
          Legal
        </Badge>
        <h1 class="font-display text-4xl leading-tight md:text-5xl">
          {title}
        </h1>
        <p class="max-w-2xl text-muted-foreground">{description}</p>
        <p class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
          Última actualización: {updatedAt}
        </p>
      </div>
    </Container>
  </section>

  <Container size="default" class="py-10 md:py-14">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">
      {/* Sticky TOC */}
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <Card>
            <CardHeader className="pb-2">
              <CardTitle className="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
                En esta página
              </CardTitle>
            </CardHeader>
            <CardContent className="pt-0">
              <nav class="flex flex-col gap-0.5">
                {
                  sections.map((s, i) => (
                    <a
                      href={`#${s.id}`}
                      class="group flex items-baseline gap-3 rounded-md px-3 py-1.5 text-sm leading-snug text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
                    >
                      <span class="font-mono text-xs tracking-wider text-muted-foreground/60 group-hover:text-primary">
                        {String(i + 1).padStart(2, "0")}
                      </span>
                      <span>{s.label}</span>
                    </a>
                  ))
                }
              </nav>
            </CardContent>
          </Card>
        </div>
      </aside>

      {/* Content */}
      <div class="lg:col-span-3">
        <Card>
          <CardContent className="px-5 py-8 md:px-10">
            <div class="prose prose-content max-w-none">
              <slot />
            </div>
          </CardContent>
        </Card>
      </div>
    </div>

    {/* CTA */}
    <Card className="mt-8 border-0 bg-primary text-primary-foreground">
      <CardContent className="flex flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
        <div class="text-center sm:text-left">
          <p class="font-display text-xl">{cta.title}</p>
          <p class="mt-1 text-sm text-primary-foreground/80">
            {cta.description}
          </p>
        </div>
        <a
          href="/contact"
          class={buttonVariants({
            variant: "ghost",
            className:
              "shrink-0 border border-primary-foreground/40 text-primary-foreground hover:bg-primary-foreground hover:text-primary",
          })}
        >
          Contactar
          <ArrowRight />
        </a>
      </CardContent>
    </Card>
  </Container>
</Main>

<style is:global>
  .prose-content {
    color: var(--foreground);
    font-size: var(--text-base);
    line-height: 1.7;
  }
  .prose-content > section {
    scroll-margin-top: 6rem;
  }
  .prose-content > section + section {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .prose-content h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    line-height: 1.15;
    margin-bottom: 1rem;
    color: var(--foreground);
  }
  .prose-content h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--foreground);
  }
  .prose-content h4 {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.25rem;
    color: var(--foreground);
  }
  .prose-content p {
    color: var(--muted-foreground);
    margin-bottom: 0.85rem;
  }
  .prose-content a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-content a:hover {
    text-decoration-thickness: 2px;
  }
  .prose-content ul {
    margin-block: 0.75rem;
    padding-left: 1.25rem;
    list-style: disc;
    color: var(--muted-foreground);
  }
  .prose-content li {
    margin-bottom: 0.4rem;
  }
  .prose-content strong {
    color: var(--foreground);
    font-weight: 600;
  }
</style>
