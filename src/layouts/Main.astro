---
import "@/styles/global.css"
import { ClientRouter, fade } from "astro:transitions"
import Header from "@/components/layout/Header.astro"
import Footer from "@/components/layout/Footer.astro"
import BackToTop from "@/components/layout/BackToTop.astro"
import { site } from "@/content/site.config"

interface Props {
  title?: string
  description?: string
}

const {
  title = `${site.name} | CRM Omnicanal`,
  description = site.description,
} = Astro.props
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <ClientRouter fallback="swap" />
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem("colorTheme")
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches
        var isDark = stored === "dark" || (!stored && prefersDark)
        document.documentElement.classList.toggle("dark", isDark)
      })()
    </script>
  </head>
  <body class="flex min-h-svh flex-col">
    <Header transition:persist transition:name="site-header" />
    <main class="flex-1" transition:animate={fade({ duration: "0.35s" })}>
      <slot />
    </main>
    <Footer transition:persist transition:name="site-footer" />
    <BackToTop transition:persist transition:name="back-to-top" />
  </body>
</html>
