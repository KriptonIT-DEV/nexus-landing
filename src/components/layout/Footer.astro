---
import { Image } from "astro:assets"
import logo from "@/assets/icons/logo-black.svg"
import instagram from "@/assets/icons/instagram.svg"
import linkedin from "@/assets/icons/linkedin.svg"
import youtube from "@/assets/icons/youtube.svg"
import whatsapp from "@/assets/icons/whatsapp.svg"
import { site, footerLinks } from "@/content/site.config"
import { Separator } from "@/components/ui/separator"
import Container from "./Container.astro"

const currentYear = new Date().getFullYear()

const socialIcon = {
  instagram,
  linkedin,
  youtube,
  whatsapp,
} as const
---

<footer class="border-t border-border bg-card text-card-foreground">
  <Container class="py-14">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-12">
      <div class="md:col-span-4">
        <Image
          src={logo}
          alt={site.name}
          class="mb-5 h-9 w-auto dark:invert"
          loading="lazy"
        />
        <p class="max-w-sm text-sm text-muted-foreground">
          {site.description}
        </p>
      </div>

      <div class="md:col-span-2 md:col-start-6">
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-widest text-foreground">
          Producto
        </h4>
        <ul class="flex flex-col gap-2 text-sm">
          {
            footerLinks.product.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-widest text-foreground">
          Legal
        </h4>
        <ul class="flex flex-col gap-2 text-sm">
          {
            footerLinks.legal.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-widest text-foreground">
          Síguenos
        </h4>
        <div class="mb-5 flex gap-2">
          {
            footerLinks.social.map((social) => {
              const iconSrc = socialIcon[social.platform]
              return (
                <a
                  href={social.href}
                  aria-label={social.label}
                  class="group flex size-10 items-center justify-center rounded-md bg-muted text-muted-foreground transition-colors hover:bg-primary"
                >
                  <Image
                    src={iconSrc}
                    alt=""
                    class="size-[18px] opacity-60 transition group-hover:opacity-100 group-hover:brightness-0 group-hover:invert"
                    loading="lazy"
                  />
                </a>
              )
            })
          }
        </div>
        <address class="text-sm not-italic text-muted-foreground">
          {site.address.line1}<br />
          {site.address.line2}
        </address>
        <a
          href={`mailto:${site.email}`}
          class="mt-2 block text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {site.email}
        </a>
      </div>
    </div>

    <Separator className="my-10" />

    <p class="text-center text-xs text-muted-foreground md:text-left">
      © {currentYear} {site.name}. Todos los derechos reservados.
    </p>
  </Container>
</footer>
